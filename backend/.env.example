# Server
PORT=3001
NODE_ENV=development

# Database (SQLite for local dev — zero setup, file-based)
# Prisma creates the file on first `prisma migrate dev`. To run against
# Postgres instead, set this to a `postgresql://...` URL and change
# `provider` in prisma/schema.prisma back to "postgresql".
DATABASE_URL=file:./dev.db

# JWT (also required for WebSocket auth)
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_hex_string
JWT_EXPIRES_IN=7d

# Where the frontend is served from. Set once: it is the allowed origin for
# HTTP CORS *and* for the websocket gateways. Point it at the machine's LAN
# address (e.g. http://10.18.200.149:3000) to play from another device.
FRONTEND_URL=http://localhost:3000

# Trust X-Forwarded-For from a reverse proxy for websocket rate limiting.
# Only set to true when deployed behind a proxy you control.
TRUST_PROXY=false
