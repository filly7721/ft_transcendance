# Server
PORT=3001
NODE_ENV=development

# Database (SQLite for local dev — zero setup, file-based)
# Prisma creates the file on first `prisma migrate dev`. To run against
# Postgres instead, set this to a `postgresql://...` URL and change
# `provider` in prisma/schema.prisma back to "postgresql".
DATABASE_URL=file:./dev.db

# JWT
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000
