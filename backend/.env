# ---- Server ----
PORT=3001
NODE_ENV=development

# ---- Database (SQLite for local dev) ----
# File-based SQLite DB (created automatically on first `prisma migrate dev`).
# Prisma generates ./prisma/dev.db relative to the schema file. To use
# Postgres instead (e.g. for a shared/staging env), set DATABASE_URL to a
# `postgresql://...` connection string AND flip `provider` back to
# "postgresql" in prisma/schema.prisma.
DATABASE_URL=file:./dev.db

# ---- JWT ----
# Access tokens expire after 7 days (JWT_EXPIRES_IN=7d).
# This secret was generated with `openssl rand -hex 32` for development.
# Rotate it for production / the defense.
JWT_SECRET=649d27cf602f084164a04349ca07d6dc984e1f64917eaa81cfdd0b8fff8a0cc5
JWT_EXPIRES_IN=7d

# ---- CORS ----
# Frontend dev server origin.
CORS_ORIGIN=http://localhost:3000
