// Prisma schema for ft_transcendence backend
// Auth + Lobbies + Profile + Friends + Chat scope.
// All models wire-compatible with SQLite (local dev) and Postgres (prod).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Local development uses SQLite (zero-setup, file-based) so the backend
  // boots without a running Postgres instance — see backendref.md §3.
  // Production should override this to "postgresql" via the same schema + a
  // matching DATABASE_URL; both providers are wire-compatible with the
  // models below (no enums, no native arrays, no @db. extensions).
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A user account. Created through /auth/register.
model User {
  /// UUID primary key. Generated by Prisma's `uuid()` default (v4 UUID).
  /// Non-enumerable: unlike auto-increment integers, a UUID cannot be guessed
  /// from another user's ID, so scraping the user list via /users/:id is
  /// infeasible. Wire-compatible with both SQLite and Postgres.
  id           String   @id @default(uuid())
  /// Unique email, used as the login identifier together with the password.
  email        String   @unique
  /// Unique public username (42-style login).
  login        String   @unique
  /// Display name shown in the UI. Defaults to the login on registration.
  displayName  String   @default("Player")
  /// bcrypt hash of the password. NEVER returned by any endpoint.
  passwordHash String
  /// Avatar URL (null = use default avatar). Stored as a relative path
  /// (e.g. "/uploads/avatars/<userId>-<ts>.png") served by express.static.
  avatarUrl    String?
  /// Creation timestamp.
  createdAt    DateTime @default(now())
  /// Last-update timestamp, managed by Prisma.
  updatedAt    DateTime @updatedAt

  /// Password-reset tokens issued for this user. Deleted with the user.
  passwordResetTokens PasswordResetToken[]

  /// Lobbies this user is the host of (creator = host).
  hostedLobbies    Lobby[]        @relation("LobbyHost")
  /// Lobbies this user has joined (including ones they host).
  lobbyMemberships LobbyMember[]  @relation("LobbyMembers")

  /// Friendships this user initiated (as requester).
  friendshipsRequested Friendship[] @relation("FriendshipRequester")
  /// Friendships this user received (as addressee).
  friendshipsReceived  Friendship[] @relation("FriendshipAddressee")
  /// Messages this user sent.
  messagesSent         Message[]    @relation("MessageSender")
  /// Messages this user received.
  messagesReceived     Message[]    @relation("MessageReceiver")
  /// Game results recorded for this user (wins, losses, draws).
  gameResults          GameResult[] @relation("GameResults")

  @@map("users")
}

/// A single-use password-reset token.
///
/// The token sent to the user (by email, or returned in dev mode) is a long
/// random string. We only store its SHA-256 hash so a database leak cannot
/// be used to reset passwords. Tokens expire (default 15 min) and are
/// single-use (`usedAt` is set once consumed).
model PasswordResetToken {
  /// Auto-incremented primary key.
  id        Int      @id @default(autoincrement())
  /// The user this token belongs to (UUID FK → User.id).
  userId    String
  /// SHA-256 hash of the raw token. Looked up by this column on reset.
  tokenHash String   @unique
  /// When the token expires. Checked on reset; old tokens are ignored.
  expiresAt DateTime
  /// Set when the token is consumed. Null = not used yet.
  usedAt    DateTime?
  /// Creation timestamp.
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

/// A lobby room for a game. Created via `POST /lobbies`.
///
/// The `id` IS the room code: 9 random digits in the format "xxx-xxx-xxx"
/// (e.g. "482-137-905"). It is both the primary key and the secret a player
/// enters to join via "JOIN BY CODE" — so it must not be guessable.
/// That is why the code is generated with `crypto.randomInt`, not `Math.random`.
model Lobby {
  /// Room code, format "xxx-xxx-xxx". Primary key AND join secret.
  id          String   @id
  /// Game slug this lobby belongs to (e.g. "minesweeper").
  game        String
  /// Human-readable lobby name shown in the browser.
  name        String
  /// User who created the lobby (the host). UUID FK → User.id.
  hostId      String
  /// Maximum players the lobby accepts (2 or 4 per the frontend form).
  maxPlayers  Int
  /// JSON-stringified `Record<string,string>` of lobby options
  /// (e.g. `{"mode":"CASUAL"}`). Stored as text because SQLite has no native
  /// JSON column; Postgres would store it the same way with this schema.
  options     String   @default("{}")
  /// Lifecycle: WAITING (open) | IN_PROGRESS | FINISHED | ABANDONED.
  /// Kept as a plain string (not a Prisma enum) so the schema is wire-
  /// compatible with both SQLite and Postgres without extra setup.
  status      String   @default("WAITING")
  /// Creation timestamp.
  createdAt   DateTime @default(now())
  /// Last-update timestamp, managed by Prisma.
  updatedAt   DateTime @updatedAt

  /// The host (creator). Resolves to a User row.
  host        User     @relation("LobbyHost", fields: [hostId], references: [id])
  /// Everyone in the lobby, including the host (host is added as the first
  /// member on creation, so `players` starts at 1).
  members     LobbyMember[]

  @@index([game])
  @@index([hostId])
  @@map("lobbies")
}

/// A user's membership in a lobby. The lobby's current player count is
/// `COUNT(*)` of rows with that `lobbyId`.
model LobbyMember {
  /// Auto-incremented primary key.
  id        Int      @id @default(autoincrement())
  /// The lobby this membership belongs to.
  lobbyId   String
  /// The user who joined (UUID FK → User.id).
  userId    String
  /// When the user joined the lobby.
  joinedAt  DateTime @default(now())

  lobby     Lobby    @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user      User     @relation("LobbyMembers", fields: [userId], references: [id], onDelete: Cascade)

  /// A user can only be a member of a given lobby once.
  @@unique([lobbyId, userId])
  @@index([lobbyId])
  @@index([userId])
  @@map("lobby_members")
}

/// A friendship relationship between two users.
///
/// Directional: `requesterId` sent the request, `addresseeId` received it.
/// One row per relationship (not two). `@@unique` prevents duplicate requests.
/// Status transitions: PENDING → ACCEPTED (friends) or PENDING → BLOCKED.
/// To unfriend, the row is deleted.
model Friendship {
  /// Auto-incremented primary key.
  id           Int      @id @default(autoincrement())
  /// The user who sent the friend request. UUID FK → User.id.
  requesterId  String
  /// The user who received the friend request. UUID FK → User.id.
  addresseeId  String
  /// PENDING (awaiting response) | ACCEPTED (friends) | BLOCKED (addressee blocked requester).
  /// Plain string (not enum) for SQLite/Postgres wire-compatibility.
  status       String   @default("PENDING")
  /// Creation timestamp.
  createdAt    DateTime @default(now())
  /// Last-update timestamp, managed by Prisma.
  updatedAt    DateTime @updatedAt

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee User @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  /// One friendship row per requester-addressee pair.
  @@unique([requesterId, addresseeId])
  /// Optimize "incoming requests for me" query.
  @@index([addresseeId, status])
  /// Optimize "my friends" query.
  @@index([requesterId, status])
  @@map("friendships")
}

/// A direct message between two users.
///
/// `senderId` sent the message, `receiverId` received it. Messages are
/// always between exactly two users (no group chat in this phase).
/// `readAt` is null until the receiver opens the conversation.
model Message {
  /// Auto-incremented primary key.
  id         Int      @id @default(autoincrement())
  /// The sender. UUID FK → User.id.
  senderId   String
  /// The receiver. UUID FK → User.id.
  receiverId String
  /// Message content. Max 1000 chars (enforced in DTO). Stored as-is;
  /// rendered with React's default escaping (no dangerouslySetInnerHTML).
  content    String
  /// When the receiver read the message. Null = unread.
  readAt     DateTime?
  /// Creation timestamp.
  createdAt  DateTime @default(now())

  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  /// Optimize "my unread inbox" query.
  @@index([receiverId, readAt])
  /// Optimize "conversation thread with user X" query.
  @@index([senderId, receiverId])
  @@map("messages")
}

/// A recorded game result for a user (for profile stats).
///
/// Created when a game ends. Used by the profile stats endpoint to show
/// wins/losses/draws per game type. The actual game result tracking will be
/// wired up when the game gateways are integrated with the lobby system.
model GameResult {
  /// Auto-incremented primary key.
  id        Int      @id @default(autoincrement())
  /// The user this result belongs to. UUID FK → User.id.
  userId    String
  /// Game slug (e.g. "minesweeper", "super-tic-tac-toe").
  game      String
  /// Result: "win" | "loss" | "draw".
  /// Plain string (not enum) for SQLite/Postgres wire-compatibility.
  result    String
  /// Optional score (e.g. time to clear minesweeper, moves in tic-tac-toe).
  score     Int?
  /// When the game was played.
  playedAt  DateTime @default(now())

  user      User     @relation("GameResults", fields: [userId], references: [id], onDelete: Cascade)

  /// Optimize "stats for user X" query.
  @@index([userId, game])
  /// Optimize "leaderboard for game X" query.
  @@index([game, result])
  @@map("game_results")
}
